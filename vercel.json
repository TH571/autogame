{
  "version": 2,
  "builds": [
    {
      "src": "src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "JWT_SECRET": "autogame-secret-key-2024",
    "JWT_EXPIRES_IN": "7d",
    "ADMIN_EMAIL": "admin@autogame.com",
    "ADMIN_PASSWORD": "admin123456"
  },
  "postgres": {
    "database": "autogame"
  }
}
